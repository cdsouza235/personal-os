# Phase 14-C local connectivity setup template.
# Copy to .env.local or run scripts/phase14c_connectivity_setup.sh.
# Never commit .env.local, real tokens, OAuth material, or API keys.

PERSONALOS_PHASE14C_GMAIL_CREDENTIAL='gmail_connector'
PERSONALOS_PHASE14C_GMAIL_SMTP_ADDRESS='your.gmail.address@example.com'
PERSONALOS_PHASE14C_GMAIL_APP_PASSWORD='paste_gmail_app_password_in_env_local_only'
PHASE14C_GMAIL_CONTROLLED_RECIPIENT='your.controlled.self.recipient@example.com'
PERSONALOS_PHASE14C_TODOIST_TOKEN='paste_todoist_token_in_env_local_only'
PERSONALOS_PHASE14C_GOOGLE_CALENDAR_CREDENTIAL='google_calendar_connector'
PERSONALOS_PHASE14C_OPENCLAW_TEST_MODE='local_test_sandbox'

PERSONALOS_OPENCLAW_MODEL_PROVIDER='openrouter'
PERSONALOS_OPENCLAW_MODEL_API_KEY='paste_openrouter_api_key_in_env_local_only'
PERSONALOS_OPENCLAW_NEMOTRON_SUPER_MODEL='nvidia/nemotron-3-super-120b-a12b'
PERSONALOS_OPENCLAW_GLM_5_2_MODEL='z-ai/glm-5.2'

# Phase D (P-RAIL-TD-01), src/personalos/rails/todoist.py live-write credential.
# Deliberately a NEW name, not a reuse of PERSONALOS_PHASE14C_TODOIST_TOKEN above: that
# var belonged to the phase14c_todoist_live_smoke module, deleted whole by P-CLEAN-02,
# and this packet's rail lives in the manifest-protected src/personalos/rails/** package
# under its own G5 gate instead. Read via os.environ only, at the credentials gate (the
# last of four fixed gates: permission -> ledger/dedupe -> rail-state -> credentials);
# never hardcoded, logged, or written to any ledger row. Per governance/RUNBOOK.md, no
# agent sandbox ever holds the real value — agents get a name-only presence check, and
# the real token lives only in Chris's host environment once P-RAIL-TD-02 (a separate,
# G5-gated packet) actually flips RAIL_STATES["todoist"] to "live".
PERSONALOS_RAIL_TODOIST_TOKEN='paste_todoist_token_in_env_local_only'
